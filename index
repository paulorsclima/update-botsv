      <td style="font-weight:600;${trendColor(p.kpi_trend)}">${trendIcon(p.kpi_trend)}</td>
    </tr>`).join('');

  renderEstoquePagination(totalPages, data.length);
}

function renderEstoquePagination(totalPages, total){
  let pag = document.getElementById('estoquePagination');
  if(!pag) return;
  if(totalPages <= 1){ pag.innerHTML=''; return; }

  const start = estoquePage * ESTOQUE_PAGE_SIZE + 1;
  const end = Math.min((estoquePage+1)*ESTOQUE_PAGE_SIZE, total);

  // Show max 7 page buttons around current
  let pages = [];
  for(let i=0;i<totalPages;i++) pages.push(i);
  const maxShow = 7;
  let sliced = pages;
  if(totalPages > maxShow){
    let s = Math.max(0, estoquePage - 3);
    let e = Math.min(totalPages, s + maxShow);
    if(e - s < maxShow) s = Math.max(0, e - maxShow);
    sliced = pages.slice(s, e);
  }

  pag.innerHTML = `
    <div style="display:flex;align-items:center;gap:6px;padding:14px 16px;border-top:1px solid #1e2535;flex-wrap:wrap;">
      <span style="font-size:12px;color:#4a5568;margin-right:6px;">Mostrando ${start}–${end} de ${total}</span>
      <button class="page-btn${estoquePage===0?' disabled':''}" onclick="goEstoquePage(0)" ${estoquePage===0?'disabled':''}>«</button>
      <button class="page-btn${estoquePage===0?' disabled':''}" onclick="goEstoquePage(${estoquePage-1})" ${estoquePage===0?'disabled':''}>‹</button>
      ${sliced.map(i=>`<button class="page-btn${i===estoquePage?' active':''}" onclick="goEstoquePage(${i})">${i+1}</button>`).join('')}
      <button class="page-btn${estoquePage===totalPages-1?' disabled':''}" onclick="goEstoquePage(${estoquePage+1})" ${estoquePage===totalPages-1?'disabled':''}>›</button>
      <button class="page-btn${estoquePage===totalPages-1?' disabled':''}" onclick="goEstoquePage(${totalPages-1})" ${estoquePage===totalPages-1?'disabled':''}>»</button>
    </div>`;
}

function goEstoquePage(p){
  const totalPages = Math.ceil(estoqueCurrent.length / ESTOQUE_PAGE_SIZE);
  if(p < 0 || p >= totalPages) return;
  estoquePage = p;
  renderEstoquePage();
  // Scroll to top of table
  const tbl = document.getElementById('estoqueBody');
  if(tbl) tbl.closest('.prod-table-wrap').scrollTop = 0;
}


