function curvaColor(c){
  if(c==='A') return 'background:#0d2618;color:#34d399;';
  if(c==='B') return 'background:#1a2f0d;color:#84cc16;';
  return 'background:#1e2535;color:#8892a4;';
}
function trendColor(t){
  if(!t||t==='SEM MOV') return 'color:#4a5568;';
  if(t==='NOVA') return 'color:#38bdf8;';
  return t.startsWith('+') ? 'color:#34d399;' : 'color:#f87171;';
}
function trendIcon(t){
  if(!t||t==='SEM MOV') return '—';
  if(t==='NOVA') return '✦ NOVA';
  return (t.startsWith('+') ? '▲ ' : '▼ ') + t;
}

// Estoque pagination state
let estoquePage = 0;
const ESTOQUE_PAGE_SIZE = 100;
let estoqueCurrent = ESTOQUE_DATA.slice(); // filtered data

function renderEstoqueTable(data, resetPage=true){
  if(resetPage) estoquePage = 0;
  estoqueCurrent = data;
  const label = document.getElementById('estoqueCountLabel');
  if(label) label.textContent = data.length + ' SKUs';
  renderEstoquePage();
}

function renderEstoquePage(){
  const data = estoqueCurrent;
  const tbody = document.getElementById('estoqueBody');
  const totalPages = Math.ceil(data.length / ESTOQUE_PAGE_SIZE);
  const start = estoquePage * ESTOQUE_PAGE_SIZE;
  const pageData = data.slice(start, start + ESTOQUE_PAGE_SIZE);

  if(!pageData.length){
    tbody.innerHTML='<tr><td colspan="7" style="text-align:center;padding:30px;color:#4a5568;">Nenhum SKU encontrado</td></tr>';
    renderEstoquePagination(0, 0);
    return;
  }

  tbody.innerHTML = pageData.map(p=>`
    <tr onclick="openModal('${p.SKU}')">
      <td><span class="sku-tag">${p.SKU}</span></td>
      <td style="max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${p.desc}">${p.desc}</td>
      <td style="font-weight:600;${p.estoque===0?'color:#f87171;':p.estoque<20?'color:#fbbf24;':'color:#34d399;'}">${p.estoque.toLocaleString('pt-BR')}</td>
      <td>${p.status==='RUPTURA'?'<span class="badge-ruptura">RUPTURA</span>':p.status==='RISCO'?'<span class="badge-risco">RISCO</span>':'<span class="badge-ok">OK</span>'}</td>
