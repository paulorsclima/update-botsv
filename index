// ---- RUPTURAS RENDER ----
let ruptSortState={col:null,dir:1};
function renderRupturas(data){
  const label=document.getElementById('ruptCountLabel');
  if(label) label.textContent=data.length+' SKUs';
  const totalRupt=data.filter(r=>r.status==='RUPTURA').length;
  const totalRisco=data.filter(r=>r.status==='RISCO').length;
  const curvaA=data.filter(r=>r.status==='RUPTURA'&&r.curva==='A').length;
  const totalSug=data.reduce((s,r)=>s+r.sugestao,0);
  document.getElementById('kpiRuptTotal').textContent=totalRupt;
  document.getElementById('kpiRiscoTotal').textContent=totalRisco;
  document.getElementById('kpiRuptCurvaA').textContent=curvaA;
  document.getElementById('kpiSugestaoTotal').textContent=totalSug.toLocaleString('pt-BR');
  const fmt2=(v)=>'R$'+v.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});
  const curvaSpan=(c)=>`<span class="kpi-badge" style="font-size:11px;${c==='A'?'background:#0d2618;color:#34d399;':c==='B'?'background:#1a2f0d;color:#84cc16;':'background:#1e2535;color:#8892a4;'}">${c}</span>`;
  document.getElementById('ruptBody').innerHTML = data.slice(0,400).map(r=>`
    <tr onclick="openModal('${r.SKU}')">
      <td><span class="sku-tag">${r.SKU}</span></td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${r.produto}">${r.produto}</td>
      <td>${r.status==='RUPTURA'?'<span class="badge-ruptura">RUPTURA</span>':'<span class="badge-risco">RISCO</span>'}</td>
      <td style="color:${r.estoque<=0?'#f87171':r.estoque<10?'#fbbf24':'#e2e8f0'};font-weight:600;">${r.estoque}</td>
      <td>${r.vd}/dia</td>
      <td>${r.cobertura<=0?'<span style="color:#f87171">0</span>':r.cobertura+' dias'}</td>
      <td style="color:#f87171;font-weight:700;">${r.sugestao>0?'+ '+r.sugestao.toLocaleString('pt-BR')+' un':'—'}</td>
      <td style="color:#34d399;">${fmt2(r.receita)}</td>
      <td>${curvaSpan(r.curva)}</td>
    </tr>`).join('');
}
renderRupturas(RUPTURAS_DATA);

function sortRupt(col){
  if(ruptSortState.col===col){ruptSortState.dir*=-1;}else{ruptSortState.col=col;ruptSortState.dir=1;}
  document.querySelectorAll('[id^="rupt-"]').forEach(el=>{el.textContent='↕';el.classList.remove('asc','desc');});
  const ico=document.getElementById('rupt-'+col);
  if(ico){ico.textContent=ruptSortState.dir===1?'↑':'↓';ico.classList.add(ruptSortState.dir===1?'asc':'desc');}
  const sorted=[...RUPTURAS_DATA].sort((a,b)=>compareVal(a,b,col,ruptSortState.dir));
  renderRupturas(sorted);
}

