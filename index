<script>
let DATA = null;

function fmt(v){return'R$ '+v.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});}
function fmtN(v){return v.toLocaleString('pt-BR');}


// ---- FETCH API ----
function initDashboard() {

// ---- CHARTS ----
const months = DATA.monthly.map(m=>{
  const [y,mo]=m.mes.split('-');
  const nomes=['','Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  return nomes[parseInt(mo)]+'/'+y.slice(2);
});
const receipts = DATA.monthly.map(m=>m.receita);

const ctx1=document.getElementById('revenueChart').getContext('2d');
const revenueChart=new Chart(ctx1,{
  type:'bar',
  data:{labels:months,datasets:[{label:'Receita',data:receipts,backgroundColor:'#6366f1',borderRadius:8,barPercentage:0.5}]},
  options:{responsive:true,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#4a5568'},grid:{color:'#1a2030'}},y:{ticks:{color:'#4a5568',callback:v=>'R$'+Math.round(v/1000)+'k'},grid:{color:'#1a2030'}}}}
});
const ctx2=document.getElementById('pieChart').getContext('2d');
new Chart(ctx2,{
  type:'doughnut',
  data:{labels:months,datasets:[{data:receipts,backgroundColor:['#6366f1','#818cf8','#38bdf8'],borderWidth:0}]},
  options:{responsive:true,cutout:'65%',plugins:{legend:{position:'bottom',labels:{color:'#8892a4',font:{size:11},padding:12}}}}
});

// ---- TOP 10 ----
const top10Body=document.getElementById('top10Body');
const maxRec=Math.max(...DATA.top10.map(t=>t.receita));
DATA.top10.forEach((t,i)=>{
  const pct=Math.round(t.receita/maxRec*100);
  top10Body.innerHTML+=`<tr onclick="openModal('${t.SKU}')"><td class="rank">${i+1}</td><td><span class="sku-tag">${t.SKU}</span></td><td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${t.Produto}">${t.Produto}</td><td>${fmt(t.receita)}</td><td>${t.estoque>0?t.estoque:'<span style="color:#f87171">0</span>'}</td></tr>`;
});

// ---- ALERTS ----
const alertList=document.getElementById('alertList');
DATA.ruptura.forEach(r=>{
  alertList.innerHTML+=`<div class="alert-item"><div class="alert-header"><span class="alert-sku">${r.SKU}</span><span style="font-size:10px;color:#f87171;font-weight:700;">EM RUPTURA</span></div><div class="alert-name" title="${r.produto}">${r.produto}</div><div class="alert-msg">Estoque: 0 un · Receita acumulada: ${fmt(r.receita)}</div></div>`;
});

// ---- INSIGHTS ----
const il=document.getElementById('insightList');
const estPad=DATA.produtos.filter(p=>p.estoque>0&&p.cobertura>90).length;
const semEstoque=DATA.produtos.filter(p=>p.estoque===0&&p.qtd>0).length;
il.innerHTML=`
  <div class="insight-item"><div class="insight-tag">📦 Estoque Parado</div><div class="insight-text">${estPad} SKUs com cobertura acima de 90 dias. Considere promoções para girar o estoque.</div></div>
  <div class="insight-item"><div class="insight-tag">🚨 Ruptura</div><div class="insight-text">${semEstoque} SKUs com estoque zerado ainda geraram vendas. Reposição urgente recomendada.</div></div>
  <div class="insight-item"><div class="insight-tag">📈 Tendência</div><div class="insight-text">Análise gerada dinamicamente após carregamento dos dados.</div></div>
`;

// ---- PRODUTOS TABLE ----
let currentData=[];
function applyFilters(){
  const q   = document.getElementById('globalSearch').value.toLowerCase().trim();
  const ano = document.getElementById('anoFilter').value;
  const mes = document.getElementById('mesFilter').value;

  // Monta chaves YYYY-MM que batem com os filtros
  const allKeys = Object.keys(DATA.vendasPorMes);
  let matchKeys = [];
  if (ano || mes) {
    matchKeys = allKeys.filter(k => {
      const [y, m] = k.split('-');
      if (ano && mes) return y === ano && m === mes;
      if (ano)        return y === ano;
      if (mes)        return m === mes;
      return false;
    });
  }

  // Base de produtos
  let base;
  if (!ano && !mes) {
    base = DATA.produtos.slice();
    document.getElementById('kpiReceita').textContent = fmt(DATA.kpis.receita);
    document.getElementById('kpiPedidos').textContent = fmtN(DATA.kpis.pedidos);
  } else if (matchKeys.length > 0) {
    const map = {};
    matchKeys.forEach(k => {
      (DATA.vendasPorMes[k] || []).forEach(v => {
        if (map[v.SKU]) {
          map[v.SKU].qtd    += v.qtd;
          map[v.SKU].receita = +(map[v.SKU].receita + v.receita).toFixed(2);
        } else { map[v.SKU] = {...v}; }
      });
    });
    base = Object.values(map).map(v => {
      const full = DATA.produtos.find(p => p.SKU === v.SKU) || {};
      return {...full, SKU:v.SKU, produto:v.produto||full.produto||'', qtd:v.qtd, receita:v.receita};
    });
    const totalR = base.reduce((s,v) => s+v.receita, 0);
    const totalQ = base.reduce((s,v) => s+v.qtd, 0);
    document.getElementById('kpiReceita').textContent = fmt(totalR);
    document.getElementById('kpiPedidos').textContent = fmtN(totalQ);
  } else {
    base = [];
    document.getElementById('kpiReceita').textContent = fmt(0);
    document.getElementById('kpiPedidos').textContent = fmtN(0);
  }

  // Filtro por texto
  if (q) base = base.filter(p =>
    (p.SKU||'').toLowerCase().includes(q) ||
    (p.produto||'').toLowerCase().includes(q)
  );

  currentData = base;
  renderProdTable(base);

  // Aba Estoque: snapshot atual, só filtra por texto
  let estoqueBase = ESTOQUE_DATA.slice();
  if (q) estoqueBase = estoqueBase.filter(p =>
    (p.SKU||'').toLowerCase().includes(q) ||
    (p.desc||'').toLowerCase().includes(q)
  );
  renderEstoqueTable(estoqueBase);
}

function statusBadge(p){
  if(!p.estoque||p.estoque===0) return '<span class="badge-ruptura">RUPTURA</span>';
  if(p.cobertura<30) return '<span class="badge-risco">RISCO</span>';
  return '<span class="badge-ok">OK</span>';
}

// Produtos pagination state
let prodPage = 0;
const PROD_PAGE_SIZE = 100;
let prodCurrent = [];

function renderProdTable(data, resetPage=true){
  if(resetPage) prodPage = 0;
  prodCurrent = data;
  const label = document.getElementById('prodCountLabel');
  if(label) label.textContent = data.length + ' produtos';
  renderProdPage();
}

function renderProdPage(){
  const data = prodCurrent;
  const tbody = document.getElementById('prodBody');
  const totalPages = Math.ceil(data.length / PROD_PAGE_SIZE);
  const start = prodPage * PROD_PAGE_SIZE;
  const pageData = data.slice(start, start + PROD_PAGE_SIZE);

  if(!pageData.length){
    tbody.innerHTML='<tr><td colspan="8" style="text-align:center;padding:30px;color:#4a5568;">Nenhum produto encontrado</td></tr>';
    renderProdPagination(0,0);
    return;
  }

  tbody.innerHTML = pageData.map(p=>`
    <tr onclick="openModal('${p.SKU}')">
      <td><span class="sku-tag">${p.SKU}</span></td>
      <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${p.produto}">${p.produto||'-'}</td>
      <td>${fmtN(p.qtd||0)}</td>
      <td>${fmt(p.receita||0)}</td>
      <td>${p.estoque!==undefined?(p.estoque||'<span style="color:#f87171">0</span>'):'-'}</td>
      <td>${p.vd!==undefined?p.vd.toFixed(2):'-'}</td>
      <td>${p.cobertura!==undefined?p.cobertura+' dias':'-'}</td>
      <td>${statusBadge(p)}</td>
    </tr>`).join('');

  renderProdPagination(totalPages, data.length);
}

function renderProdPagination(totalPages, total){
  let pag = document.getElementById('prodPagination');
  if(!pag) return;
  if(totalPages <= 1){ pag.innerHTML=''; return; }

  const start = prodPage * PROD_PAGE_SIZE + 1;
  const end = Math.min((prodPage+1)*PROD_PAGE_SIZE, total);
  const maxShow = 7;
  let pages = [...Array(totalPages).keys()];
  let sliced = pages;
  if(totalPages > maxShow){
    let s = Math.max(0, prodPage-3);
    let e = Math.min(totalPages, s+maxShow);
    if(e-s < maxShow) s = Math.max(0, e-maxShow);
    sliced = pages.slice(s,e);
  }

  pag.innerHTML = `
    <div style="display:flex;align-items:center;gap:6px;padding:14px 16px;border-top:1px solid #1e2535;flex-wrap:wrap;">
      <span style="font-size:12px;color:#4a5568;margin-right:6px;">Mostrando ${start}–${end} de ${total}</span>
      <button class="page-btn" onclick="goProdPage(0)" ${prodPage===0?'disabled':''}>«</button>
      <button class="page-btn" onclick="goProdPage(${prodPage-1})" ${prodPage===0?'disabled':''}>‹</button>
      ${sliced.map(i=>`<button class="page-btn${i===prodPage?' active':''}" onclick="goProdPage(${i})">${i+1}</button>`).join('')}
      <button class="page-btn" onclick="goProdPage(${prodPage+1})" ${prodPage===totalPages-1?'disabled':''}>›</button>
      <button class="page-btn" onclick="goProdPage(${totalPages-1})" ${prodPage===totalPages-1?'disabled':''}>»</button>
    </div>`;
}

function goProdPage(p){
  const totalPages = Math.ceil(prodCurrent.length / PROD_PAGE_SIZE);
  if(p < 0 || p >= totalPages) return;
  prodPage = p;
  renderProdPage();
  const tbl = document.getElementById('prodBody');
  if(tbl) tbl.closest('.prod-table-wrap').scrollTop = 0;
}


// Init produtos
renderProdTable(DATA.produtos);
prodCurrent = DATA.produtos.slice();

// ---- NAVIGATION ----
function showPage(name,el){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  el.classList.add('active');
}

// ---- MODAL ----
function openModal(sku){
  const p=DATA.produtos.find(x=>x.SKU===sku)||{};
  const nome=p.produto||sku;
  document.getElementById('modalSku').textContent=sku;
  document.getElementById('modalName').textContent=nome;
  document.getElementById('mQtd').textContent=fmtN(p.qtd||0)+' un';
  document.getElementById('mReceita').textContent=fmt(p.receita||0);
  document.getElementById('mEstoque').textContent=fmtN(p.estoque||0)+' un';
  document.getElementById('mVd').textContent=(p.vd||0).toFixed(2)+'/dia';
  document.getElementById('mCob').textContent=(p.cobertura||0)+' dias';
