function renderInsights(){
  const fmt2=(v)=>'R$'+v.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});
  const curvaSpan=(c)=>`<span class="kpi-badge" style="font-size:11px;${c==='A'?'background:#0d2618;color:#34d399;':c==='B'?'background:#1a2f0d;color:#84cc16;':'background:#1e2535;color:#8892a4;'}">${c}</span>`;

  document.getElementById('insAltaBody').innerHTML = INSIGHTS_DATA.alta.map(p=>`
    <tr onclick="openModal('${p.SKU}')">
      <td><span class="sku-tag">${p.SKU}</span></td>
      <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${p.produto}</td>
      <td>${p.qtd_30||0}</td>
      <td style="color:#34d399;font-weight:700;">▲ ${p.trend_pct===999?'NOVA':p.trend_pct+'%'}</td>
      <td>${curvaSpan(p.curva)}</td>
    </tr>`).join('');

  document.getElementById('insQuedaBody').innerHTML = INSIGHTS_DATA.queda.map(p=>`
    <tr onclick="openModal('${p.SKU}')">
      <td><span class="sku-tag">${p.SKU}</span></td>
      <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${p.produto}</td>
      <td>${p.qtd_30||0}</td>
      <td style="color:#f87171;font-weight:700;">▼ ${p.trend_pct}%</td>
      <td>${curvaSpan(p.curva)}</td>
    </tr>`).join('');

  document.getElementById('insPaadoBody').innerHTML = INSIGHTS_DATA.parado.map(p=>`
    <tr onclick="openModal('${p.SKU}')">
      <td><span class="sku-tag">${p.SKU}</span></td>
      <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${p.produto}</td>
      <td style="color:#fbbf24;font-weight:700;">${p.estoque}</td>
      <td>${p.cobertura} dias</td>
      <td>${curvaSpan(p.curva)}</td>
    </tr>`).join('');

  document.getElementById('insOpBody').innerHTML = INSIGHTS_DATA.oportunidade.map(p=>`
    <tr onclick="openModal('${p.SKU}')">
      <td><span class="sku-tag">${p.SKU}</span></td>
      <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${p.produto}</td>
      <td style="color:#34d399;font-weight:700;">${fmt2(p.receita)}</td>
      <td style="color:#f87171;font-weight:700;">+ ${p.sugestao} un</td>
      <td>${curvaSpan(p.curva)}</td>
    </tr>`).join('');
}
