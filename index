  document.getElementById('kpiProj60').textContent=data.reduce((s,r)=>s+r.proj60,0).toLocaleString('pt-BR');
  document.getElementById('kpiProjSug').textContent=data.reduce((s,r)=>s+r.sugestao,0).toLocaleString('pt-BR');
  const curvaSpan=(c)=>`<span class="kpi-badge" style="font-size:11px;${c==='A'?'background:#0d2618;color:#34d399;':c==='B'?'background:#1a2f0d;color:#84cc16;':'background:#1e2535;color:#8892a4;'}">${c}</span>`;
  document.getElementById('projBody').innerHTML = data.slice(0,300).map(r=>`
    <tr onclick="openModal('${r.SKU}')">
      <td><span class="sku-tag">${r.SKU}</span></td>
      <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${r.produto}">${r.produto}</td>
      <td style="color:${r.estoque<=0?'#f87171':r.estoque<10?'#fbbf24':'#34d399'};font-weight:600;">${r.estoque}</td>
      <td>${r.vd}/dia</td>
      <td style="font-weight:600;">${r.proj30.toLocaleString('pt-BR')}</td>
      <td>${r.proj60.toLocaleString('pt-BR')}</td>
      <td>${r.proj90.toLocaleString('pt-BR')}</td>
      <td>${r.cobertura+' dias'}</td>
      <td style="color:${r.sugestao>0?'#f87171':'#34d399'};font-weight:700;">${r.sugestao>0?'+ '+r.sugestao.toLocaleString('pt-BR')+' un':'—'}</td>
      <td>${curvaSpan(r.curva)}</td>
    </tr>`).join('');
}
renderProjecoes(PROJ_DATA);

function sortProj(col){
  if(projSortState.col===col){projSortState.dir*=-1;}else{projSortState.col=col;projSortState.dir=1;}
  document.querySelectorAll('[id^="proj-"]').forEach(el=>{el.textContent='↕';el.classList.remove('asc','desc');});
  const ico=document.getElementById('proj-'+col);
  if(ico){ico.textContent=projSortState.dir===1?'↑':'↓';ico.classList.add(projSortState.dir===1?'asc':'desc');}
  const sorted=[...PROJ_DATA].sort((a,b)=>compareVal(a,b,col,projSortState.dir));
  renderProjecoes(sorted);
}

// ---- EXPORT MODAL ----
let exportFiltered = [];

function openExportModal(){
  document.getElementById('exportSearch').value = '';
  document.getElementById('exportStatusFilter').value = '';
  document.getElementById('exportCurvaFilter').value = '';
  document.getElementById('exportOverlay').style.display = 'flex';
  filterExportList();
}

function closeExportModal(e){
  if(e.target === document.getElementById('exportOverlay')) closeExportModalDirect();
}
function closeExportModalDirect(){
  document.getElementById('exportOverlay').style.display = 'none';
}

function filterExportList(){
  const q      = document.getElementById('exportSearch').value.toLowerCase().trim();
  const status = document.getElementById('exportStatusFilter').value;
  const curva  = document.getElementById('exportCurvaFilter').value;

  exportFiltered = ESTOQUE_DATA.filter(p => {
    const matchQ = !q || (p.SKU||'').toLowerCase().includes(q) || (p.desc||'').toLowerCase().includes(q);
    const matchS = !status || p.status === status;
    const matchC = !curva  || p.curva  === curva;
    return matchQ && matchS && matchC;
  });

  renderExportList();
}

function renderExportList(){
  const container = document.getElementById('exportList');
  document.getElementById('exportListCount').textContent = exportFiltered.length + ' exibidos';

  if(!exportFiltered.length){
    container.innerHTML = '<div style="padding:30px;text-align:center;color:#4a5568;">Nenhum produto encontrado</div>';
    updateExportCount();
    return;
  }

  container.innerHTML = `
    <table style="width:100%;border-collapse:collapse;">
      <thead style="position:sticky;top:0;background:#161b27;z-index:2;">
        <tr>
          <th style="padding:10px 12px;text-align:left;font-size:11px;color:#4a5568;font-weight:600;border-bottom:1px solid #1e2535;width:36px;"></th>
          <th style="padding:10px 12px;text-align:left;font-size:11px;color:#4a5568;font-weight:600;border-bottom:1px solid #1e2535;">SKU</th>
          <th style="padding:10px 12px;text-align:left;font-size:11px;color:#4a5568;font-weight:600;border-bottom:1px solid #1e2535;">Descrição</th>
          <th style="padding:10px 12px;text-align:center;font-size:11px;color:#4a5568;font-weight:600;border-bottom:1px solid #1e2535;">Estoque</th>
          <th style="padding:10px 12px;text-align:center;font-size:11px;color:#4a5568;font-weight:600;border-bottom:1px solid #1e2535;">Sugestão</th>
          <th style="padding:10px 12px;text-align:center;font-size:11px;color:#4a5568;font-weight:600;border-bottom:1px solid #1e2535;">Status</th>
          <th style="padding:10px 12px;text-align:center;font-size:11px;color:#4a5568;font-weight:600;border-bottom:1px solid #1e2535;">Curva</th>
        </tr>
      </thead>
      <tbody>
        ${exportFiltered.map((p,i) => `
          <tr style="border-bottom:1px solid #1a2030;cursor:pointer;" onclick="toggleExportItem(${i})" id="erow-${i}">
            <td style="padding:9px 12px;text-align:center;">
              <input type="checkbox" id="echk-${i}" style="width:15px;height:15px;cursor:pointer;accent-color:#6366f1;" onchange="updateExportCount()" onclick="event.stopPropagation()">
            </td>
            <td style="padding:9px 12px;"><span class="sku-tag">${p.SKU}</span></td>
            <td style="padding:9px 12px;font-size:12.5px;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${p.desc}">${p.desc}</td>
            <td style="padding:9px 12px;text-align:center;font-weight:600;color:${p.estoque===0?'#f87171':p.estoque<20?'#fbbf24':'#34d399'}">${p.estoque}</td>
            <td style="padding:9px 12px;text-align:center;font-weight:600;color:${p.sugestao>0?'#f87171':'#8892a4'}">${p.sugestao>0?'+ '+p.sugestao:'-'}</td>
            <td style="padding:9px 12px;text-align:center;">${p.status==='RUPTURA'?'<span class="badge-ruptura">RUPTURA</span>':p.status==='RISCO'?'<span class="badge-risco">RISCO</span>':'<span class="badge-ok">OK</span>'}</td>
            <td style="padding:9px 12px;text-align:center;"><span class="kpi-badge" style="font-size:11px;${curvaColor(p.curva)}">${p.curva}</span></td>
          </tr>`).join('')}
      </tbody>
    </table>`;

  updateExportCount();
}

function toggleExportItem(i){
  const chk = document.getElementById('echk-'+i);
  if(chk){ chk.checked = !chk.checked; updateExportCount(); }
}

function selectAllExport(val){
  exportFiltered.forEach((_,i)=>{
    const chk = document.getElementById('echk-'+i);
    if(chk) chk.checked = val;
  });
  updateExportCount();
}

function updateExportCount(){
  let count = 0;
  exportFiltered.forEach((_,i)=>{ const c=document.getElementById('echk-'+i); if(c&&c.checked) count++; });
  document.getElementById('exportSelectedCount').textContent = count + ' produto' + (count!==1?'s':'') + ' selecionado' + (count!==1?'s':'');
}

function doExport(){
  const selected = exportFiltered.filter((_,i)=>{ const c=document.getElementById('echk-'+i); return c&&c.checked; });
  if(!selected.length){ alert('Selecione ao menos um produto para exportar.'); return; }

  const lines = ['SKU/Descrição/Estoque Atual/Sugestão de Compra/Curva'];
  selected.forEach(p=>{
    const desc = (p.desc||'').replace(/\//g,'-');
    lines.push(`${p.SKU}/${desc}/${p.estoque}/${p.sugestao}/${p.curva}`);
  });

  const blob = new Blob([lines.join('\n')], {type:'text/plain;charset=utf-8'});
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = 'pedido_compra_santim.txt';
  a.click();
  URL.revokeObjectURL(url);
}

// ---- SIDEBAR TOGGLE ----
function toggleSidebar(){
  const sb=document.getElementById('sidebar');
  const main=document.querySelector('.main');
  const btn=document.getElementById('sidebarToggle');
  const collapsed=sb.classList.toggle('collapsed');
  main.classList.toggle('collapsed',collapsed);
  btn.classList.toggle('collapsed',collapsed);
  btn.textContent=collapsed?'›':'‹';
  btn.title=collapsed?'Expandir menu':'Recolher menu';
}

}

(async function loadData() {
  const URL = "https://script.google.com/macros/s/AKfycbwn8FDdXhWv3Hmu0m4GxUJ6LJHgUXoWm9oo0ugr2345QuYB92V4T35n7bVMzHGJww/exec";
  const msg = document.getElementById('loadingMsg');
  try {
    msg.textContent = 'Conectando ao Google Sheets...';
    const res  = await fetch(URL);
    if (!res.ok) throw new Error('HTTP ' + res.status);
    msg.textContent = 'Processando dados...';
    const json = await res.json();

    if (json.erro) throw new Error(json.erro);

    // Popula as variáveis globais
    DATA          = json;
    ESTOQUE_DATA  = json.estoque  || [];
    KPIS_ESTOQUE  = json.kpisEstoque || {};

    // Preenche filtros de ano/mês dinamicamente
    const anos  = [...new Set(Object.keys(DATA.vendasPorMes).map(k => k.split('-')[0]))].sort();
    const meses = [...new Set(Object.keys(DATA.vendasPorMes).map(k => k.split('-')[1]))].sort();
    const selAno = document.getElementById('anoFilter');
    const selMes = document.getElementById('mesFilter');
    if (selAno) anos.forEach(a  => { const o=document.createElement('option'); o.value=a; o.textContent=a; selAno.appendChild(o); });
    if (selMes) meses.forEach(m => { const o=document.createElement('option'); o.value=m; o.textContent=m; selMes.appendChild(o); });

    // Remove loading e inicializa
    document.getElementById('loadingOverlay').style.display = 'none';
    initDashboard();

  } catch(err) {
    msg.style.color = '#f87171';
    msg.innerHTML   = '⚠ Erro ao carregar dados: ' + err.message +
      '<br><br><button onclick="loadData()" style="background:#6366f1;border:none;color:#fff;padding:8px 20px;border-radius:8px;cursor:pointer;font-size:13px;">Tentar novamente</button>';
    console.error('SalesIQ fetch error:', err);
  }
})();
</script>
