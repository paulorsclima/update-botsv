<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SalesIQ — Santim</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:#0f1117;color:#e2e8f0;display:flex;min-height:100vh;}
.sidebar{width:220px;min-height:100vh;background:#161b27;display:flex;flex-direction:column;padding:24px 0;position:fixed;left:0;top:0;bottom:0;border-right:1px solid #1e2535;z-index:100;transition:width 0.25s ease;}
.sidebar.collapsed{width:62px;}
.logo{padding:12px 16px 20px;font-size:20px;font-weight:700;color:#fff;letter-spacing:-0.5px;white-space:nowrap;overflow:hidden;transition:all 0.2s;}
.logo span{color:#6366f1;}
.sidebar.collapsed .logo{padding:8px 4px 12px;justify-content:center;font-size:0;}
.sidebar.collapsed .logo img{height:36px;width:auto;}
.nav-section{font-size:10px;font-weight:600;color:#4a5568;text-transform:uppercase;letter-spacing:1px;padding:8px 20px 4px;white-space:nowrap;overflow:hidden;transition:opacity 0.2s;}
.sidebar.collapsed .nav-section{opacity:0;height:0;padding:0;margin:0;}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 20px;color:#8892a4;font-size:13.5px;cursor:pointer;border-left:3px solid transparent;transition:all 0.15s;white-space:nowrap;overflow:hidden;}
.nav-item:hover{background:#1e2535;color:#e2e8f0;}
.nav-item.active{background:#1e2535;color:#fff;border-left:3px solid #6366f1;font-weight:600;}
.nav-item .icon{font-size:16px;min-width:20px;text-align:center;}
.nav-label{transition:opacity 0.2s,width 0.2s;overflow:hidden;}
.sidebar.collapsed .nav-label{opacity:0;width:0;}
.sidebar.collapsed .nav-item{padding:10px 0;justify-content:center;}
.sidebar-footer{margin-top:auto;padding:16px 20px;border-top:1px solid #1e2535;font-size:12px;color:#4a5568;white-space:nowrap;overflow:hidden;}
.sidebar.collapsed .sidebar-footer{padding:16px 0;text-align:center;font-size:0;}
.sidebar.collapsed .sidebar-footer::before{content:"✓";font-size:14px;color:#4a5568;display:block;}
/* Toggle button */
.sidebar-toggle{position:fixed;left:208px;top:22px;width:26px;height:26px;background:#6366f1;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:200;transition:left 0.25s ease;box-shadow:0 2px 8px rgba(99,102,241,0.4);font-size:13px;color:#fff;user-select:none;}
.sidebar-toggle.collapsed{left:50px;}
.sidebar-toggle:hover{background:#4f46e5;}
.main{margin-left:220px;flex:1;padding:28px 32px;transition:margin-left 0.25s ease;}
.main.collapsed{margin-left:62px;}
/* TOPBAR */
.topbar{display:flex;gap:12px;align-items:center;margin-bottom:24px;flex-wrap:wrap;}
.search-wrap{flex:1;min-width:200px;position:relative;}
.search-wrap input{width:100%;background:#161b27;border:1px solid #1e2535;border-radius:10px;padding:10px 16px 10px 40px;font-size:13.5px;color:#e2e8f0;outline:none;transition:border 0.2s;}
.search-wrap input:focus{border-color:#6366f1;}
.search-wrap .ico{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#4a5568;font-size:15px;}
.filter-select{background:#161b27;border:1px solid #1e2535;border-radius:10px;padding:10px 14px;font-size:13px;color:#e2e8f0;outline:none;cursor:pointer;}
.filter-select:focus{border-color:#6366f1;}
/* PAGE HEADER */
.page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:22px;flex-wrap:wrap;gap:10px;}
.page-title{font-size:20px;font-weight:700;color:#fff;}
.page-subtitle{font-size:12px;color:#5a6a80;margin-top:2px;}
/* PAGES */
.page{display:none;}
.page.active{display:block;}
/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
.kpi-card{background:#161b27;border:1px solid #1e2535;border-radius:12px;padding:18px 20px;}
.kpi-label{font-size:11px;color:#5a6a80;font-weight:500;text-transform:uppercase;letter-spacing:0.5px;}
.kpi-value{font-size:24px;font-weight:700;color:#fff;margin:5px 0 4px;}
.kpi-badge{display:inline-flex;align-items:center;gap:4px;font-size:11.5px;font-weight:600;padding:3px 8px;border-radius:20px;}
.up{background:#0d2618;color:#34d399;}.down{background:#2a0d12;color:#f87171;}.neutral{background:#1e2535;color:#8892a4;}
/* CHARTS ROW */
.charts-row{display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:20px;}
.card{background:#161b27;border:1px solid #1e2535;border-radius:12px;padding:20px 22px;}
.card-title{font-size:13.5px;font-weight:600;color:#c0c9d9;margin-bottom:2px;}
.card-subtitle{font-size:11.5px;color:#4a5568;margin-bottom:16px;}
/* BOTTOM */
.bottom-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
/* TABLE */
table{width:100%;border-collapse:collapse;}
thead th{font-size:11px;text-transform:uppercase;letter-spacing:0.5px;color:#4a5568;padding:7px 9px;text-align:left;border-bottom:1px solid #1e2535;}
tbody tr{border-bottom:1px solid #1a2030;cursor:pointer;}
tbody tr:hover{background:#1e2535;}
tbody td{font-size:12.5px;color:#c0c9d9;padding:9px 9px;}
.rank{font-size:11px;font-weight:700;color:#4a5568;}
.sku-tag{font-size:11px;background:#1e2535;color:#6366f1;padding:2px 7px;border-radius:4px;font-weight:600;cursor:pointer;white-space:nowrap;}
.sku-tag:hover{background:#6366f1;color:#fff;}
.bar-wrap{background:#1e2535;border-radius:4px;height:5px;width:70px;}
.bar-fill{height:5px;border-radius:4px;background:#6366f1;}
/* ALERTS */
.alert-list{display:flex;flex-direction:column;gap:9px;}
.alert-item{background:#1a1020;border:1px solid #3d1a2e;border-radius:10px;padding:11px 13px;}
.alert-item.warn{background:#1a1505;border-color:#3d300a;}
.alert-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;}
.alert-sku{font-size:11px;font-weight:700;color:#f87171;}
.alert-sku.warn{color:#fbbf24;}
.alert-name{font-size:12px;color:#c0c9d9;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:240px;}
.alert-msg{font-size:11px;color:#6b7280;margin-top:2px;}
/* INSIGHTS */
.insight-list{display:flex;flex-direction:column;gap:9px;}
.insight-item{background:#0d1a2a;border:1px solid #1a2f45;border-radius:10px;padding:11px 13px;}
.insight-tag{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#38bdf8;margin-bottom:3px;}
.insight-text{font-size:12px;color:#94a3b8;}
/* PRODUTO PAGE */
.prod-table-wrap{overflow-x:auto;max-height:600px;overflow-y:auto;}
.badge-ruptura{background:#2a0d12;color:#f87171;font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px;}
.page-btn{background:#1e2535;border:1px solid #2a3448;color:#8892a4;font-size:12px;padding:5px 10px;border-radius:6px;cursor:pointer;transition:all 0.15s;min-width:32px;}
.page-btn:hover{background:#2a3448;color:#fff;}
.page-btn.active{background:#6366f1;color:#fff;border-color:#6366f1;font-weight:700;}
.page-btn.disabled,.page-btn:disabled{opacity:0.3;cursor:not-allowed;}
.sortable{cursor:pointer;user-select:none;white-space:nowrap;}
.sortable:hover{color:#c0c9d9;background:#1a2030;}
.sort-ico{font-size:10px;color:#4a5568;margin-left:3px;}
.sort-ico.asc{color:#6366f1;}
.sort-ico.desc{color:#6366f1;}
.chart-type-btn{background:#1e2535;border:1px solid #2a3448;color:#8892a4;font-size:11px;padding:4px 9px;border-radius:6px;cursor:pointer;transition:all 0.15s;line-height:1;}
.chart-type-btn:hover{background:#2a3448;color:#fff;}
.chart-type-btn.active{background:#6366f1;color:#fff;border-color:#6366f1;}
.badge-ok{background:#0d2618;color:#34d399;font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px;}
.badge-risco{background:#1a1505;color:#fbbf24;font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px;}
/* SKU DETAIL MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:1000;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:#161b27;border:1px solid #1e2535;border-radius:16px;padding:28px;width:700px;max-width:95vw;max-height:90vh;overflow-y:auto;position:relative;}
.modal-close{position:absolute;top:16px;right:18px;font-size:20px;color:#4a5568;cursor:pointer;}
.modal-close:hover{color:#fff;}
.modal-sku{font-size:11px;background:#1e2535;color:#6366f1;padding:3px 9px;border-radius:5px;font-weight:700;display:inline-block;margin-bottom:6px;}
.modal-name{font-size:16px;font-weight:700;color:#fff;margin-bottom:16px;line-height:1.4;}
.modal-kpis{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px;}
.modal-kpi{background:#0f1117;border-radius:10px;padding:14px;}
.modal-kpi-label{font-size:10px;color:#4a5568;text-transform:uppercase;letter-spacing:0.5px;}
.modal-kpi-value{font-size:20px;font-weight:700;color:#fff;margin-top:4px;}
/* TABS */
.tabs{display:flex;gap:4px;margin-bottom:14px;}
.tab{padding:6px 13px;border-radius:6px;font-size:12px;font-weight:500;color:#5a6a80;cursor:pointer;}
.tab.active{background:#1e2535;color:#fff;}
/* RESPONSIVE */
@media(max-width:900px){
  .kpi-grid{grid-template-columns:repeat(2,1fr);}
  .charts-row,.bottom-grid{grid-template-columns:1fr;}
  .sidebar{width:60px;}
  .sidebar .nav-item span:not(.icon),.nav-section,.logo,.sidebar-footer{display:none;}
  .main{margin-left:60px;}
}
</style>
</head>
<body>
<!-- LOADING OVERLAY -->
<div id="loadingOverlay" style="
  position:fixed;inset:0;background:#0f1117;z-index:9999;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;
">
  <div style="width:48px;height:48px;border:4px solid #1e2535;border-top:4px solid #6366f1;border-radius:50%;animation:spin 0.8s linear infinite;"></div>
  <div style="color:#8892a4;font-size:14px;font-family:Inter,sans-serif;" id="loadingMsg">Carregando dados...</div>
  <style>@keyframes spin{to{transform:rotate(360deg)}}</style>
</div>

<div class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()" title="Recolher menu">‹</div>
<aside class="sidebar" id="sidebar">
  <div class="logo" style="display:flex;justify-content:center;align-items:center;padding:16px 8px 16px;"><img src="data:image/png;base64," alt="BotSV" style="height:76px;width:auto;object-fit:contain;display:block;"></div>
  <div class="nav-section">Principal</div>
  <div class="nav-item active" onclick="showPage('dashboard',this)" title="Dashboard"><span class="icon">⬛</span><span class="nav-label">Dashboard</span></div>
  <div class="nav-item" onclick="showPage('produtos',this)" title="Produtos"><span class="icon">📦</span><span class="nav-label">Produtos</span></div>
  <div class="nav-item" onclick="showPage('estoque',this)" title="Estoque"><span class="icon">🏪</span><span class="nav-label">Estoque</span></div>
  <div class="nav-section" style="margin-top:10px;">Análise</div>
  <div class="nav-item" onclick="showPage('insights',this)" title="Insights"><span class="icon">💡</span><span class="nav-label">Insights</span></div>
  <div class="nav-item" onclick="showPage('rupturas',this)" title="Rupturas"><span class="icon">🚨</span><span class="nav-label">Rupturas</span></div>
  <div class="nav-item" onclick="showPage('projecoes',this)" title="Projeções"><span class="icon">📈</span><span class="nav-label">Projeções</span></div>
  <div class="nav-section" style="margin-top:10px;">Config</div>
  <div class="nav-item" title="Configurações"><span class="icon">⚙️</span><span class="nav-label">Configurações</span></div>
  <div class="sidebar-footer">Santim · Google Sheets ✓</div>
</aside>

<main class="main">
  <!-- TOPBAR -->
  <div class="topbar">
    <div class="search-wrap">
      <span class="ico">🔍</span>
      <input type="text" id="globalSearch" placeholder="Buscar por produto, SKU..." oninput="applyFilters()">
    </div>
    <select class="filter-select" id="anoFilter" onchange="applyFilters()">
      <option value="">Anos</option>
      <option value="2025">2025</option>
      <option value="2026">2026</option>
      <option value="2027">2027</option>
      <option value="2028">2028</option>
      <option value="2029">2029</option>
      <option value="2030">2030</option>
    </select>
    <select class="filter-select" id="mesFilter" onchange="applyFilters()">
      <option value="">Meses</option>
      <option value="01">Janeiro</option>
      <option value="02">Fevereiro</option>
      <option value="03">Março</option>
      <option value="04">Abril</option>
      <option value="05">Maio</option>
      <option value="06">Junho</option>
      <option value="07">Julho</option>
      <option value="08">Agosto</option>
      <option value="09">Setembro</option>
      <option value="10">Outubro</option>
      <option value="11">Novembro</option>
      <option value="12">Dezembro</option>
    </select>
  </div>

  <!-- DASHBOARD PAGE -->
  <div id="page-dashboard" class="page active">
    <div class="page-header">
      <div><div class="page-title">Dashboard Geral</div><div class="page-subtitle">Santim · Nov 2025 – Jan 2026</div></div>
    </div>
    <div class="kpi-grid">
      <div class="kpi-card"><div class="kpi-label">Receita Total</div><div class="kpi-value" id="kpiReceita">—</div><span class="kpi-badge up" id="kpiCrescimento">—</span></div>
      <div class="kpi-card"><div class="kpi-label">Transações</div><div class="kpi-value" id="kpiPedidos">—</div><span class="kpi-badge neutral">3 meses</span></div>
      <div class="kpi-card"><div class="kpi-label">Ticket Médio</div><div class="kpi-value" id="kpiTicket">—</div><span class="kpi-badge neutral">por venda</span></div>
      <div class="kpi-card"><div class="kpi-label">SKUs em Ruptura</div><div class="kpi-value" style="color:#f87171;" id="kpiRuptura">—</div><span class="kpi-badge down">▼ Estoque zerado</span></div>
    </div>
    <div class="charts-row">
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2px;">
          <div class="card-title">Receita por Mês</div>
          <div style="display:flex;gap:4px;">
            <button onclick="setChartType('bar')" id="btnBar" class="chart-type-btn active" title="Gráfico de Barras">▐▌</button>
            <button onclick="setChartType('line')" id="btnLine" class="chart-type-btn" title="Gráfico de Linha">╱</button>
          </div>
        </div>
        <div class="card-subtitle">Nov 2025 – Jan 2026</div>
        <canvas id="revenueChart" height="100"></canvas>
      </div>
      <div class="card">
        <div class="card-title">Distribuição Mensal</div>
        <div class="card-subtitle">Participação por mês</div>
        <canvas id="pieChart" height="140"></canvas>
      </div>
    </div>
    <div class="bottom-grid">
      <div class="card">
        <div class="card-title">🏆 Top 10 Produtos</div>
        <div class="card-subtitle">Por receita total acumulada</div>
        <div class="tabs"><div class="tab active">Receita</div></div>
        <table>
          <thead><tr><th>#</th><th>SKU</th><th>Produto</th><th>Receita</th><th>Estoque</th></tr></thead>
          <tbody id="top10Body"></tbody>
        </table>
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div class="card">
          <div class="card-title">🚨 Ruptura Crítica</div>
          <div class="card-subtitle">SKUs com estoque zerado e vendas ativas</div>
          <div class="alert-list" id="alertList"></div>
        </div>
        <div class="card">
          <div class="card-title">💡 Insights</div>
          <div class="card-subtitle">Análise automática dos dados</div>
          <div class="insight-list" id="insightList"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- PRODUTOS PAGE -->
  <div id="page-produtos" class="page">
    <div class="page-header">
      <div><div class="page-title">Produtos</div><div class="page-subtitle">Análise por SKU · Use a busca e filtros acima</div></div>
      <div style="font-size:12px;color:#4a5568;" id="prodCountLabel"></div>
    </div>
    <div class="card" style="padding:0;">
      <div class="prod-table-wrap">
        <table>
          <thead><tr>
            <th class="sortable" onclick="sortTable('prod','SKU')">SKU <span class="sort-ico" id="prod-SKU">↕</span></th>
            <th class="sortable" onclick="sortTable('prod','produto')">Produto <span class="sort-ico" id="prod-produto">↕</span></th>
            <th class="sortable" onclick="sortTable('prod','qtd')">Qtd Vendida <span class="sort-ico" id="prod-qtd">↕</span></th>
            <th class="sortable" onclick="sortTable('prod','receita')">Receita <span class="sort-ico" id="prod-receita">↕</span></th>
            <th class="sortable" onclick="sortTable('prod','estoque')">Estoque Atual <span class="sort-ico" id="prod-estoque">↕</span></th>
            <th class="sortable" onclick="sortTable('prod','vd')">Venda/Dia <span class="sort-ico" id="prod-vd">↕</span></th>
            <th class="sortable" onclick="sortTable('prod','cobertura')">Cobertura <span class="sort-ico" id="prod-cobertura">↕</span></th>
            <th>Status</th>
          </tr></thead>
          <tbody id="prodBody"></tbody>
        </table>
        <div id="prodPagination"></div>
      </div>
    </div>
  </div>

  <!-- ESTOQUE PAGE -->
  <div id="page-estoque" class="page">
    <div class="page-header">
      <div><div class="page-title">Estoque</div><div class="page-subtitle">Análise de estoque por SKU · Sugestão baseada nos últimos 30 dias</div></div>
      <div style="display:flex;align-items:center;gap:12px;">
        <div style="font-size:12px;color:#4a5568;" id="estoqueCountLabel"></div>
        <button onclick="openExportModal()" style="display:flex;align-items:center;gap:7px;background:#6366f1;border:none;color:#fff;font-size:13px;font-weight:600;padding:9px 18px;border-radius:8px;cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#4f46e5'" onmouseout="this.style.background='#6366f1'">
          ⬇ Exportar Pedido
        </button>
      </div>
    </div>
    <!-- KPIs estoque -->
    <div class="kpi-grid" style="margin-bottom:20px;">
      <div class="kpi-card"><div class="kpi-label">Total de SKUs</div><div class="kpi-value">—</div><span class="kpi-badge neutral">cadastrados</span></div>
      <div class="kpi-card"><div class="kpi-label">Em Ruptura</div><div class="kpi-value" style="color:#f87171;">—</div><span class="kpi-badge down">▼ estoque zerado</span></div>
      <div class="kpi-card"><div class="kpi-label">Em Risco</div><div class="kpi-value" style="color:#fbbf24;">—</div><span class="kpi-badge" style="background:#1a1505;color:#fbbf24;">⚠ &lt; 30 dias</span></div>
      <div class="kpi-card"><div class="kpi-label">Curva A (70% receita)</div><div class="kpi-value">—</div><span class="kpi-badge up">▲ prioridade alta</span></div>
    </div>
    <div class="card" style="padding:0;">
      <div class="prod-table-wrap">
        <table>
          <thead><tr>
            <th class="sortable" onclick="sortTable('est','SKU')">SKU <span class="sort-ico" id="est-SKU">↕</span></th>
            <th class="sortable" onclick="sortTable('est','desc')">Descrição <span class="sort-ico" id="est-desc">↕</span></th>
            <th class="sortable" onclick="sortTable('est','estoque')">Estoque Atual <span class="sort-ico" id="est-estoque">↕</span></th>
            <th>Status</th>
            <th class="sortable" onclick="sortTable('est','sugestao')">Sugestão de Compra <span class="sort-ico" id="est-sugestao">↕</span></th>
            <th class="sortable" onclick="sortTable('est','curva')">Curva ABC <span class="sort-ico" id="est-curva">↕</span></th>
            <th class="sortable" onclick="sortTable('est','kpi_trend')">Tendência (30d) <span class="sort-ico" id="est-kpi_trend">↕</span></th>
          </tr></thead>
          <tbody id="estoqueBody"></tbody>
        </table>
        <div id="estoquePagination"></div>
      </div>
    </div>
  </div>

  <!-- INSIGHTS PAGE -->
  <div id="page-insights" class="page">
    <div class="page-header">
      <div><div class="page-title">💡 Insights</div><div class="page-subtitle">Análise automática · Oportunidades e alertas com base nos dados</div></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">
      <div class="card">
        <div class="card-title" style="color:#34d399;">▲ Top 10 em Alta (Jan vs Dez)</div>
        <div class="card-subtitle">Produtos com maior crescimento percentual</div>
        <table><thead><tr><th>SKU</th><th>Produto</th><th>Qtd Jan</th><th>Crescimento</th><th>Curva</th></tr></thead>
        <tbody id="insAltaBody"></tbody></table>
      </div>
      <div class="card">
        <div class="card-title" style="color:#f87171;">▼ Top 10 em Queda (Jan vs Dez)</div>
        <div class="card-subtitle">Produtos com maior queda percentual</div>
        <table><thead><tr><th>SKU</th><th>Produto</th><th>Qtd Jan</th><th>Queda</th><th>Curva</th></tr></thead>
        <tbody id="insQuedaBody"></tbody></table>
