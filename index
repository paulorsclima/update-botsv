// ---- SORT STATE ----
const sortState = {
  prod: {col: null, dir: 1},
  est:  {col: null, dir: 1}
};

function sortTable(table, col){
  const state = sortState[table];
  if(state.col === col){ state.dir *= -1; }
  else { state.col = col; state.dir = 1; }

  // Reset all icons for this table
  document.querySelectorAll(`[id^="${table}-"]`).forEach(el=>{
    el.textContent='↕'; el.classList.remove('asc','desc');
  });
  const ico = document.getElementById(`${table}-${col}`);
  if(ico){ ico.textContent = state.dir===1?'↑':'↓'; ico.classList.add(state.dir===1?'asc':'desc'); }

  if(table==='prod'){
    const sorted = [...currentData].sort((a,b)=>compareVal(a,b,col,state.dir));
    renderProdTable(sorted, false); // false = don't reset sort
  } else {
    // For estoque, sort current rendered data
    const q = document.getElementById('globalSearch').value.toLowerCase().trim();
    let base = ESTOQUE_DATA.slice();
    if(q) base = base.filter(p=>(p.SKU||'').toLowerCase().includes(q)||(p.desc||'').toLowerCase().includes(q));
    const sorted = base.sort((a,b)=>compareVal(a,b,col,state.dir));
    renderEstoqueTable(sorted, false);
  }
}

function compareVal(a, b, col, dir){
  let va = a[col], vb = b[col];
  if(va===undefined||va===null) va='';
  if(vb===undefined||vb===null) vb='';
  // Numeric?
  if(typeof va === 'number' && typeof vb === 'number') return (va - vb) * dir;
  // Parse trend percentages like "+25%" "-10%"
  const pA = parseFloat(String(va).replace('%','').replace('+',''));
  const pB = parseFloat(String(vb).replace('%','').replace('+',''));
  if(!isNaN(pA) && !isNaN(pB)) return (pA - pB) * dir;
  // String compare
  return String(va).localeCompare(String(vb), 'pt-BR') * dir;
}

